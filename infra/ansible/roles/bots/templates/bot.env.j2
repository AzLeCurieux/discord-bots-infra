# =============================================================================
# Fichier .env — {{ bot_name }}
# Généré par Ansible — NE PAS MODIFIER MANUELLEMENT
# Permissions : 0600 (lecture uniquement par bot-runner)
# =============================================================================

# ── Token Discord ─────────────────────────────────────────────────────────────
DISCORD_TOKEN={{ discord_token }}

# ── IDs Discord ───────────────────────────────────────────────────────────────
GUILD_ID={{ guild_id }}
{% if log_channel_id %}
LOG_CHANNEL_ID={{ log_channel_id }}
{% endif %}
{% if status_channel_id %}
STATUS_CHANNEL_ID={{ status_channel_id }}
{% endif %}

# ── Configuration bot ─────────────────────────────────────────────────────────
{% if bot_name == 'bot-moderation' %}
HEALTH_PORT=8080
BANNED_WORDS=spam,insulte,publicite,arnaque,discord.gg
{% endif %}
{% if bot_name == 'bot-status' %}
DAILY_REPORT_CRON=0 9 * * *
TZ=Europe/Paris
{% endif %}

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
