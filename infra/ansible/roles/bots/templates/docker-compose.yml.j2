# Generated by Ansible. Manual changes will be overwritten.

services:

  bot-moderation:
    image: "{{ bot_images['bot-moderation'].image }}:{{ bot_images['bot-moderation'].tag }}"
    container_name: bot-moderation
    restart: unless-stopped
    env_file:
      - ./bot-moderation/.env
    ports:
      - "127.0.0.1:8081:8080"  # Health check exposé uniquement en local
    volumes:
      - ./bot-moderation/data:/app/data:rw
    deploy:
      resources:
        limits:
          memory: "{{ bot_memory_limit }}"
          cpus: "{{ bot_cpu_limit }}"
        reservations:
          memory: "{{ bot_memory_reservation }}"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
        tag: "bot-moderation"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      - bots
      - monitoring
    labels:
      - "com.discord-bots.service=bot-moderation"
      - "com.discord-bots.managed-by=ansible"

  # ── Bot de statut (Node.js / discord.js) ─────────────────────────────────────
  bot-status:
    image: "{{ bot_images['bot-status'].image }}:{{ bot_images['bot-status'].tag }}"
    container_name: bot-status
    restart: unless-stopped
    env_file:
      - ./bot-status/.env
    volumes:
      - ./bot-status/data:/app/data:rw
    deploy:
      resources:
        limits:
          memory: "{{ bot_memory_limit }}"
          cpus: "{{ bot_cpu_limit }}"
        reservations:
          memory: "{{ bot_memory_reservation }}"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
        tag: "bot-status"
    healthcheck:
      test: ["CMD", "node", "-e", "process.exit(0)"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    networks:
      - bots
      - monitoring
    labels:
      - "com.discord-bots.service=bot-status"
      - "com.discord-bots.managed-by=ansible"

# ── Réseaux ──────────────────────────────────────────────────────────────────
networks:
  bots:
    name: discord-bots
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/24
  monitoring:
    name: monitoring
    external: true  # Réseau partagé avec la stack de monitoring
